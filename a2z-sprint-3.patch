+export const useRecentlyViewedStore = create<RecentlyViewedState>()(
+  persist(
+    (set) => ({
+      productIds: [],
+      record: (productId) =>
+        set((state) => ({
+          productIds: [productId, ...state.productIds.filter((id) => id !== productId)].slice(0, MAX_ITEMS),
+        })),
+    }),
+    { name: "a2z-recently-viewed" }
+  )
+);
